# Exclude everything by default
*

# But include these files
!package.json
!README.md
!LICENSE
!dist/
!config.example.yaml
!docs/

# Include TypeScript definitions if any
# !*.d.ts

# Keep directory structure for included files
!dist/**
!docs/**

# Exclude config that should not be shipped
!config.example.yaml

# Keep license
!LICENSE

# Allow .npmrc if needed
# !.npmrc