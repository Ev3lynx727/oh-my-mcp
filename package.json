{
  "name": "@ev3lynx/oh-my-mcp",
  "version": "1.0.1",
  "description": "Native MCP gateway with management layer on top of supergateway",
  "author": "ev3lynx727",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "oh-my-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "config.example.yaml"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.0",
    "nanoid": "^5.1.6",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3",
    "supergateway": "^3.4.3",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "supertest": "^7.2.2",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
